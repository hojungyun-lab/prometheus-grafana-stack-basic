    "id": null,
    "links": [],
    "panels": [
        {
            "title": "📊 애플리케이션 상태",
            "type": "row",
            "gridPos": {
                "h": 1,
                "w": 24,
                "x": 0,
                "y": 0
            },
            "collapsed": false
        },
        {
            "title": "총 요청 수",
            "type": "stat",
            "datasource": {
                "type": "prometheus",
                "uid": "prometheus"
            },
            "gridPos": {
                "h": 5,
                "w": 6,
                "x": 0,
                "y": 1
            },
            "fieldConfig": {
                "defaults": {
                    "thresholds": {
                        "mode": "absolute",
                        "steps": [
                            {
                                "color": "blue",
                                "value": null
                            }
                        ]
                    }
                },
                "overrides": []
            },
            "targets": [
                {
                    "expr": "app_requests_total{job=\"custom-exporter\"}",
                    "legendFormat": "Total Requests"
                }
            ]
        },
        {
            "title": "활성 사용자",
            "type": "stat",
            "datasource": {
                "type": "prometheus",
                "uid": "prometheus"
            },
            "gridPos": {
                "h": 5,
                "w": 6,
                "x": 6,
                "y": 1
            },
            "fieldConfig": {
                "defaults": {
                    "thresholds": {
                        "mode": "absolute",
                        "steps": [
                            {
                                "color": "green",
                                "value": null
                            },
                            {
                                "color": "yellow",
                                "value": 10
                            },
                            {
                                "color": "red",
                                "value": 5
                            }
                        ]
                    }
                },
                "overrides": []
            },
            "targets": [
                {
                    "expr": "app_active_users{job=\"custom-exporter\"}",
                    "legendFormat": "Active Users"
                }
            ]
        },
        {
            "title": "에러율",
            "type": "gauge",
            "datasource": {
                "type": "prometheus",
                "uid": "prometheus"
            },
            "gridPos": {
                "h": 5,
                "w": 6,
                "x": 12,
                "y": 1
            },
            "fieldConfig": {
                "defaults": {
                    "unit": "percentunit",
                    "min": 0,
                    "max": 1,
                    "thresholds": {
                        "mode": "absolute",
                        "steps": [
                            {
                                "color": "green",
                                "value": null
                            },
                            {
                                "color": "yellow",
                                "value": 0.02
                            },
                            {
                                "color": "orange",
                                "value": 0.05
                            },
                            {
                                "color": "red",
                                "value": 0.1
                            }
                        ]
                    }
                },
                "overrides": []
            },
            "targets": [
                {
                    "expr": "app_error_rate{job=\"custom-exporter\"}",
                    "legendFormat": "Error Rate"
                }
            ]
        },
        {
            "title": "요청 처리 속도",
            "type": "stat",
            "datasource": {
                "type": "prometheus",
                "uid": "prometheus"
            },
            "gridPos": {
                "h": 5,
                "w": 6,
                "x": 18,
                "y": 1
            },
            "fieldConfig": {
                "defaults": {
                    "unit": "reqps",
                    "thresholds": {
                        "mode": "absolute",
                        "steps": [
                            {
                                "color": "green",
                                "value": null
                            }
                        ]
                    }
                },
                "overrides": []
            },
            "targets": [
                {
                    "expr": "rate(app_requests_total{job=\"custom-exporter\"}[5m])",
                    "legendFormat": "Req/s"
                }
            ]
        },
        {
            "title": "📈 추이",
            "type": "row",
            "gridPos": {
                "h": 1,
                "w": 24,
                "x": 0,
                "y": 6
            },
            "collapsed": false
        },
        {
            "title": "요청 수 추이",
            "type": "timeseries",
            "datasource": {
                "type": "prometheus",
                "uid": "prometheus"
            },
            "gridPos": {
                "h": 8,
                "w": 12,
                "x": 0,
                "y": 7
            },
            "fieldConfig": {
                "defaults": {
                    "unit": "reqps",
                    "custom": {
                        "lineWidth": 2,
                        "fillOpacity": 20,
                        "gradientMode": "scheme",
                        "showPoints": "never"
                    }
                },
                "overrides": []
            },
            "targets": [
                {
                    "expr": "rate(app_requests_total{job=\"custom-exporter\"}[5m])",
                    "legendFormat": "Requests/s"
                }
            ]
        },
        {
            "title": "활성 사용자 추이",
            "type": "timeseries",
            "datasource": {
                "type": "prometheus",
                "uid": "prometheus"
            },
            "gridPos": {
                "h": 8,
                "w": 12,
                "x": 12,
                "y": 7
            },
            "fieldConfig": {
                "defaults": {
                    "custom": {
                        "lineWidth": 2,
                        "fillOpacity": 25,
                        "gradientMode": "scheme",
                        "showPoints": "never"
                    },
                    "thresholds": {
                        "mode": "absolute",
                        "steps": [
                            {
                                "color": "red",
                                "value": null
                            },
                            {
                                "color": "yellow",
                                "value": 10
                            },
                            {
                                "color": "green",
                                "value": 30
                            }
                        ]
                    }
                },
                "overrides": []
            },
            "targets": [
                {
                    "expr": "app_active_users{job=\"custom-exporter\"}",
                    "legendFormat": "Active Users"
                }
            ]
        },
        {
            "title": "응답 시간 분포 (Histogram)",
            "type": "timeseries",
            "datasource": {
                "type": "prometheus",
                "uid": "prometheus"
            },
            "gridPos": {
                "h": 8,
                "w": 12,
                "x": 0,
                "y": 15
            },
            "fieldConfig": {
                "defaults": {
                    "unit": "s",
                    "custom": {
                        "lineWidth": 2,
                        "fillOpacity": 10,
                        "showPoints": "never"
                    }
                },
                "overrides": []
            },
            "targets": [
                {
                    "expr": "histogram_quantile(0.50, rate(app_request_duration_seconds_bucket{job=\"custom-exporter\"}[5m]))",
                    "legendFormat": "p50"
                },
                {
                    "expr": "histogram_quantile(0.90, rate(app_request_duration_seconds_bucket{job=\"custom-exporter\"}[5m]))",
                    "legendFormat": "p90"
                },
                {
                    "expr": "histogram_quantile(0.99, rate(app_request_duration_seconds_bucket{job=\"custom-exporter\"}[5m]))",
                    "legendFormat": "p99"
                }
            ]
        },
        {
